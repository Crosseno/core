{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://crosseno.org/schema/core-snapshot-v1.json",
    "title": "Crosseno core domain snapshot v1",
    "type": "object",
    "additionalProperties": false,
    "required": ["schema", "version", "duplicatePlacementPolicy", "grid", "entries"],
    "properties": {
        "schema": {"const": "crosseno-core-snapshot"},
        "version": {"const": 1},
        "duplicatePlacementPolicy": {"enum": ["forbid", "allow"]},
        "grid": {
            "type": "object",
            "additionalProperties": false,
            "required": ["rows", "columns", "cells"],
            "properties": {
                "rows": {"type": "integer", "minimum": 1},
                "columns": {"type": "integer", "minimum": 1},
                "cells": {
                    "type": "array",
                    "items": {
                        "oneOf": [
                            {
                                "type": "object",
                                "additionalProperties": false,
                                "required": ["state", "symbol"],
                                "properties": {
                                    "state": {"enum": ["empty", "blocked"]},
                                    "symbol": {"type": "null"}
                                }
                            },
                            {
                                "type": "object",
                                "additionalProperties": false,
                                "required": ["state", "symbol"],
                                "properties": {
                                    "state": {"const": "filled"},
                                    "symbol": {"type": "string", "minLength": 1, "pattern": "^\\S+$"}
                                }
                            }
                        ]
                    }
                }
            }
        },
        "entries": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["answer", "senseKey", "placement"],
                "properties": {
                    "answer": {
                        "type": "object",
                        "additionalProperties": false,
                        "required": ["key", "displayText", "cells"],
                        "properties": {
                            "key": {"type": "string", "minLength": 1, "maxLength": 255, "pattern": "^\\S+$"},
                            "displayText": {"type": "string", "minLength": 1},
                            "cells": {
                                "type": "array",
                                "minItems": 1,
                                "items": {"type": "string", "minLength": 1, "pattern": "^\\S+$"}
                            }
                        }
                    },
                    "senseKey": {
                        "oneOf": [
                            {"type": "null"},
                            {"type": "string", "minLength": 1, "maxLength": 255, "pattern": "^\\S+$"}
                        ]
                    },
                    "placement": {
                        "type": "object",
                        "additionalProperties": false,
                        "required": ["row", "column", "direction", "length"],
                        "properties": {
                            "row": {"type": "integer", "minimum": 0},
                            "column": {"type": "integer", "minimum": 0},
                            "direction": {"enum": ["horizontal", "vertical"]},
                            "length": {"type": "integer", "minimum": 1}
                        }
                    }
                }
            }
        }
    }
}
